# Filipino Food API — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# Cloudflare Workers
# Your Cloudflare account ID — found in the Cloudflare dashboard
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare KV Namespace
# Created via: npx wrangler kv namespace create RATE_LIMIT
# Add the returned ID to wrangler.toml
KV_NAMESPACE_ID=

# Cloudflare R2 (added in v1.2)
# R2 bucket name for storing dish images
R2_BUCKET_NAME=

# fal.ai (added in v1.2)
# API key for AI image generation
# Get yours at: https://fal.ai
FAL_API_KEY=

# API Key System (added in v1.3)
# Secret used to sign and verify API keys
API_KEY_SECRET=