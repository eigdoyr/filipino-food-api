{
  "name": "filipino-food-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "validate": "ts-node scripts/validate.ts",
    "dev": "wrangler dev",
    "build:index": "ts-node scripts/build-index.ts",
    "add:images": "FAL_API_KEY=$(grep FAL_API_KEY .dev.vars | cut -d '=' -f2) ts-node scripts/add-images.ts",
    "upload:images": "ts-node -r dotenv/config scripts/upload-to-r2.ts dotenv_config_path=.dev.vars",
    "update:r2urls": "ts-node scripts/update-r2-urls.ts",
    "backfill:cache": "ts-node -r dotenv/config scripts/backfill-r2-cache.ts dotenv_config_path=.dev.vars",
    "add:dimensions": "ts-node scripts/add-image-dimensions.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "packages/data/dishes/*.json": [
      "npm run build:index",
      "npm run validate"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eigdoyr/filipino-food-api.git"
  },
  "keywords": [],
  "author": "ryodgie",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/eigdoyr/filipino-food-api/issues"
  },
  "homepage": "https://github.com/eigdoyr/filipino-food-api#readme",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1059.0",
    "@fal-ai/client": "^1.10.1",
    "@hono/swagger-ui": "^0.6.1",
    "hono": "^4.12.23",
    "image-size": "^2.0.2",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.92.0"
  }
}
